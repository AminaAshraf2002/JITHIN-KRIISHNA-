<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jithin Krishnan · Portfolio</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        bg: "#0A0A0A",
                        accent: "#FF3C00",
                        accentSec: "#FFD60A"
                    },
                    fontFamily: {
                        bebas: ['"Bebas Neue"', 'sans-serif'],
                        outfit: ['"Outfit"', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <!-- GSAP for Animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <style>
        body {
            background-color: #0A0A0A;
            color: #FFFFFF;
            font-family: 'Outfit', sans-serif;
            overflow-x: hidden;
            cursor: none;
        }

        /* Noise Texture */
        .noise-overlay {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            pointer-events: none;
            z-index: 9998;
            opacity: 0.05;
            background-image: url('data:image/svg+xml;utf8,%3Csvg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"%3E%3Cfilter id="noiseFilter"%3E%3CfeTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="3" stitchTiles="stitch"/%3E%3C/filter%3E%3Crect width="100%25" height="100%25" filter="url(%23noiseFilter)"/%3E%3C/svg%3E');
        }

        /* Custom Cursor */
        .cursor-dot, .cursor-ring {
            position: fixed;
            top: 0; left: 0;
            transform: translate(-50%, -50%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 9999;
        }
        .cursor-dot {
            width: 8px; height: 8px;
            background-color: #FF3C00;
        }
        .cursor-ring {
            width: 40px; height: 40px;
            border: 1px solid rgba(255, 60, 0, 0.5);
            transition: width 0.3s ease, height 0.3s ease, background-color 0.3s ease;
        }
        body:has(.hoverable:hover) .cursor-ring,
        body:has(a:hover) .cursor-ring,
        body:has(button:hover) .cursor-ring {
            width: 70px;
            height: 70px;
            background-color: rgba(255, 60, 0, 0.1);
            border-color: #FF3C00;
        }

        /* Preloader */
        #preloader {
            position: fixed;
            inset: 0;
            background-color: #0A0A0A;
            z-index: 10000;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }
        .preloader-letters {
            display: flex;
            font-size: 10rem;
            line-height: 1;
            overflow: hidden;
            font-family: 'Bebas Neue', sans-serif;
        }
        .preloader-j {
            transform: translateY(-100%);
        }
        .preloader-k {
            color: #FF3C00;
            transform: translateY(-100%);
        }
        .preloader-line-wrapper {
            width: 200px;
            height: 4px;
            background: rgba(255,255,255,0.1);
            margin: 20px 0;
            overflow: hidden;
        }
        .preloader-line {
            width: 100%;
            height: 100%;
            background-color: #FF3C00;
            transform: translateX(-101%);
        }
        .preloader-subtitle {
            opacity: 0;
            font-size: 1.2rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            font-weight: 300;
        }

        /* Navbar */
        nav {
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            background: rgba(10, 10, 10, 0.7);
        }

        /* Hero Watermark */
        .watermark {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 25vw;
            color: rgba(255, 255, 255, 0.02);
            font-family: 'Bebas Neue', sans-serif;
            z-index: 0;
            pointer-events: none;
            white-space: nowrap;
            user-select: none;
        }

        /* Image Frame */
        .image-frame {
            position: relative;
        }
        .image-frame::after {
            content: '';
            position: absolute;
            top: 30px; left: 30px;
            width: 100%; height: 100%;
            border: 2px solid #FF3C00;
            z-index: -1;
            transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .image-frame:hover::after {
            transform: translate(-10px, -10px);
        }

        /* Marquee */
        .marquee-wrapper {
            overflow: hidden;
            white-space: nowrap;
            border-top: 1px solid rgba(255,255,255,0.05);
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding: 24px 0;
            background: #0A0A0A;
            display: flex;
        }
        .marquee-content {
            display: inline-block;
            animation: marquee 30s linear infinite;
        }
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* Skill bars */
        .skill-bar-bg {
            width: 100%;
            height: 4px;
            background: rgba(255,255,255,0.1);
            position: relative;
            overflow: hidden;
        }
        .skill-bar-fill {
            height: 100%;
            background: #FF3C00;
            width: 0%;
        }

        /* Tool Tags */
        .tool-tag {
            position: relative;
            overflow: hidden;
            transition: color 0.3s ease;
            z-index: 1;
        }
        .tool-tag::before {
            content: '';
            position: absolute;
            bottom: 0; left: 0; width: 100%; height: 0%;
            background: #FF3C00;
            transition: height 0.4s cubic-bezier(0.25, 1, 0.5, 1);
            z-index: -1;
        }
        .tool-tag:hover {
            color: #fff;
            border-color: #FF3C00;
        }
        .tool-tag:hover::before {
            height: 100%;
        }

        /* Timeline */
        .timeline-line {
            position: absolute;
            left: 11px;
            top: 24px;
            bottom: 0;
            width: 2px;
            background: linear-gradient(to bottom, #FF3C00, transparent);
        }
        .timeline-dot {
            width: 24px;
            height: 24px;
            background: #0A0A0A;
            border: 3px solid #FF3C00;
            border-radius: 50%;
            position: absolute;
            left: 0;
            top: 0;
            box-shadow: 0 0 15px rgba(255, 60, 0, 0.5);
        }

        /* Portfolio Cards */
        .portfolio-card {
            position: relative;
            overflow: hidden;
            background: #111;
        }
        .portfolio-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
            opacity: 0.8;
        }
        .portfolio-card:hover img {
            transform: scale(1.05);
            opacity: 1;
        }
        .portfolio-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, #FF3C00 0%, rgba(255,60,0,0) 80%);
            opacity: 0;
            transform: translateY(100%);
            transition: all 0.6s cubic-bezier(0.25, 1, 0.5, 1);
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 40px;
        }
        .portfolio-card:hover .portfolio-overlay {
            opacity: 0.95;
            transform: translateY(0);
        }
        .portfolio-bg-letter {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            font-size: 20vw;
            color: rgba(255,255,255,0.03);
            font-family: 'Bebas Neue', sans-serif;
            pointer-events: none;
            z-index: 1;
        }

        /* Certifications */
        .cert-card {
            border-left: 2px solid rgba(255,255,255,0.1);
            transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
            background: rgba(255,255,255,0.02);
        }
        .cert-card:hover {
            border-left-color: #FF3C00;
            background: rgba(255,255,255,0.04);
            transform: translateX(10px);
        }

        /* Enhanced About & Award Section */
        .glass-panel {
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        .award-card {
            background: linear-gradient(135deg, rgba(255, 214, 10, 0.1) 0%, rgba(255, 60, 0, 0.05) 100%);
            border: 1px solid rgba(255, 214, 10, 0.3);
            position: relative;
            overflow: hidden;
            transform-style: preserve-3d;
            perspective: 1000px;
        }
        .award-card::before {
            content: '';
            position: absolute;
            top: -50%; left: -50%;
            width: 200%; height: 200%;
            background: conic-gradient(from 0deg, transparent 0%, rgba(255, 214, 10, 0.3) 25%, transparent 50%);
            animation: rotate-glow 4s linear infinite;
            z-index: -1;
        }
        .award-card::after {
            content: '';
            position: absolute;
            inset: 2px;
            background: #111;
            z-index: -1;
            border-radius: inherit;
        }
        @keyframes rotate-glow {
            100% { transform: rotate(360deg); }
        }
        .floating-icon {
            animation: float-y 3s ease-in-out infinite;
        }
        @keyframes float-y {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .about-text-mask {
            overflow: hidden;
            display: inline-block;
            vertical-align: top;
        }
    </style>
</head>
<body>
    <div class="noise-overlay"></div>
    <div class="cursor-dot"></div>
    <div class="cursor-ring"></div>

    <!-- Preloader -->
    <div id="preloader">
        <div class="preloader-letters">
            <span class="preloader-j">J</span>
            <span class="preloader-k">K</span>
        </div>
        <div class="preloader-line-wrapper">
            <div class="preloader-line"></div>
        </div>
        <div class="preloader-subtitle">Jithin Krishnan · Portfolio</div>
    </div>

    <!-- Navbar -->
    <nav class="fixed top-0 w-full z-50 border-b border-white/5 opacity-0 invisible" id="navbar">
        <div class="max-w-7xl mx-auto px-6 py-5 flex justify-between items-center">
            <a href="#" class="font-bebas text-3xl tracking-wider flex items-end">
                J<span class="text-accent">.</span>K
            </a>
            <div class="hidden md:flex gap-8 text-sm font-medium tracking-widest uppercase">
                <a href="#about" class="hover:text-accent transition-colors">About</a>
                <a href="#experience" class="hover:text-accent transition-colors">Experience</a>
                <a href="#work" class="hover:text-accent transition-colors">Work</a>
                <a href="#contact" class="hover:text-accent transition-colors">Contact</a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center pt-20 overflow-hidden">
        <div class="watermark" id="hero-watermark">DESIGN</div>
        
        <div class="max-w-7xl mx-auto px-6 w-full grid grid-cols-1 lg:grid-cols-2 gap-20 items-center z-10">
            
            <div class="space-y-8 hero-content">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-[2px] bg-accent"></div>
                    <span class="uppercase tracking-widest text-sm text-gray-400 font-medium">Available for Projects</span>
                </div>
                
                <h1 class="font-bebas text-[5rem] md:text-[7rem] leading-[0.85] tracking-wide">
                    JITHIN <br>
                    <span class="text-accent">KRISHNAN</span>
                </h1>
                
                <div class="space-y-4 max-w-lg">
                    <h2 class="text-xl md:text-2xl font-light text-gray-300">Graphic Designer · Video Editor · Visual Storyteller</h2>
                    <p class="text-gray-400 leading-relaxed font-light">
                        I craft bold, cinematic designs and engaging motion pieces for forward-thinking brands. Based in Palakkad, Kerala, bringing stories to life through pixels and keyframes.
                    </p>
                </div>
                
                <div class="flex flex-wrap gap-6 pt-4">
                    <a href="#work" class="px-8 py-4 bg-accent text-white font-medium hover:bg-white hover:text-bg transition-colors duration-300">View My Work</a>
                    <a href="#contact" class="px-8 py-4 border border-white/20 font-medium hover:border-accent hover:text-accent transition-colors duration-300">Let's Talk</a>
                </div>
            </div>

            <div class="relative hero-image hidden lg:block">
                <div class="image-frame w-[400px] h-[550px] ml-auto">
                    <img src="img.png" alt="Jithin Krishnan" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700">
                    
                    <div class="absolute -bottom-10 -left-10 bg-[#111] border border-white/10 p-5 rounded-sm flex items-center gap-4 shadow-2xl animate-[pulse_3s_ease-in-out_infinite]">
                        <span class="text-accentSec text-2xl"><i class="fa-solid fa-star"></i></span>
                        <div>
                            <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Award Winner</p>
                            <p class="font-bebas text-xl tracking-wider">Best Performer 2025</p>
                        </div>
                    </div>

                    <div class="absolute top-10 -right-16 bg-[#111] border border-white/10 px-5 py-3 flex flex-col items-center">
                        <span class="font-bebas text-3xl text-accent">1+</span>
                        <span class="text-[10px] text-gray-400 uppercase tracking-widest">Yrs Exp</span>
                    </div>

                    <div class="absolute top-32 -right-10 bg-[#111] border border-white/10 px-5 py-3 flex flex-col items-center">
                        <span class="font-bebas text-3xl text-white">50+</span>
                        <span class="text-[10px] text-gray-400 uppercase tracking-widest">Projects</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Marquee -->
    <div class="marquee-wrapper border-y border-white/5 opacity-0 section-reveal">
        <div class="marquee-content font-bebas text-3xl md:text-5xl tracking-widest text-gray-500">
            Social Media Design <span class="diamond">◆</span> 
            Branding & Identity <span class="diamond">◆</span> 
            Video Editing <span class="diamond">◆</span> 
            Hoarding Designs <span class="diamond">◆</span> 
            App Banners <span class="diamond">◆</span> 
            Brochures <span class="diamond">◆</span> 
            Motion Graphics <span class="diamond">◆</span> 
            Social Media Design <span class="diamond">◆</span> 
            Branding & Identity <span class="diamond">◆</span> 
            Video Editing <span class="diamond">◆</span> 
            Hoarding Designs <span class="diamond">◆</span> 
            App Banners <span class="diamond">◆</span> 
            Brochures <span class="diamond">◆</span> 
            Motion Graphics <span class="diamond">◆</span> 
        </div>
    </div>

    <!-- About Section -->
    <section id="about" class="py-40 px-6 relative">
        <!-- Background Accents -->
        <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-accent/5 to-transparent pointer-events-none -z-10"></div>
        <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-accentSec/10 rounded-full blur-[120px] pointer-events-none -z-10"></div>

        <div class="max-w-7xl mx-auto glass-panel rounded-3xl p-10 md:p-24 relative overflow-hidden">
            
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 relative z-10">
                <!-- Left Column -->
                <div class="space-y-10">
                    <div class="about-fade-up inline-flex items-center gap-3 border border-accent/30 bg-accent/5 text-accent text-xs font-bold uppercase tracking-widest px-5 py-2 rounded-full">
                        <i class="fa-solid fa-user-astronaut"></i> About The Creator
                    </div>
                    
                    <h2 class="font-bebas text-5xl md:text-7xl tracking-wide leading-none">
                        <div class="about-text-mask"><span class="about-title-line block">The Story</span></div>
                        <div class="about-text-mask"><span class="about-title-line block">Behind The <span class="text-accent">Work</span></span></div>
                    </h2>
                    
                    <div class="space-y-6 text-gray-400 font-light leading-relaxed text-lg">
                        <p class="about-para"><i class="fa-solid fa-quote-left text-accentSec/30 text-2xl mr-3"></i>I started my journey with a deep curiosity for how visuals communicate emotions. Today, I am a dedicated Graphic Designer and Video Editor blending aesthetic appeal with strategic intent.</p>
                        <p class="about-para">Over the past year, I have honed my skills across various disciplines—from print media to dynamic motion graphics—ensuring every project not only looks premium but also performs exceptionally.</p>
                        <p class="about-para">Currently shaping brand narratives and creating high-impact campaigns in Kerala's thriving tech landscape.</p>
                    </div>

                    <!-- Enhanced Award Card -->
                    <div class="award-card rounded-2xl p-8 mt-12 hoverable group cursor-default">
                        <div class="flex items-start gap-6 relative z-10">
                            <div class="w-16 h-16 rounded-full bg-accentSec/10 border border-accentSec/30 flex items-center justify-center shrink-0 floating-icon">
                                <i class="fa-solid fa-trophy text-accentSec text-2xl group-hover:scale-125 transition-transform duration-500"></i>
                            </div>
                            <div>
                                <h3 class="font-bebas text-3xl text-white tracking-widest mb-2 group-hover:text-accentSec transition-colors duration-300">Best Performer Award 2025</h3>
                                <p class="text-sm text-gray-400 leading-relaxed font-light">Awarded for outstanding creative contributions and consistent excellence at <span class="text-white font-medium">Inspite Technologies, Infopark Kochi.</span></p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column (Skills & Tools) -->
                <div class="space-y-16">
                    <!-- Skills -->
                    <div class="space-y-8">
                        <h3 class="about-fade-up font-bebas text-4xl tracking-widest flex items-center gap-3">
                            <i class="fa-solid fa-chart-pie text-accent"></i> Core Competencies
                        </h3>
                        
                        <div class="space-y-6">
                            <!-- Skill -->
                            <div class="about-skill-item">
                                <div class="flex justify-between text-sm uppercase tracking-widest mb-3 font-medium">
                                    <span><i class="fa-solid fa-hashtag text-accent mr-2"></i>Social Media Design</span>
                                    <span class="text-accent">95%</span>
                                </div>
                                <div class="skill-bar-bg rounded-full h-2"><div class="skill-bar-fill rounded-full" data-width="95%"></div></div>
                            </div>
                            <!-- Skill -->
                            <div class="about-skill-item">
                                <div class="flex justify-between text-sm uppercase tracking-widest mb-3 font-medium">
                                    <span><i class="fa-solid fa-fingerprint text-accent mr-2"></i>Branding</span>
                                    <span class="text-accent">90%</span>
                                </div>
                                <div class="skill-bar-bg rounded-full h-2"><div class="skill-bar-fill rounded-full" data-width="90%"></div></div>
                            </div>
                            <!-- Skill -->
                            <div class="about-skill-item">
                                <div class="flex justify-between text-sm uppercase tracking-widest mb-3 font-medium">
                                    <span><i class="fa-solid fa-film text-accent mr-2"></i>Video Editing</span>
                                    <span class="text-accent">88%</span>
                                </div>
                                <div class="skill-bar-bg rounded-full h-2"><div class="skill-bar-fill rounded-full" data-width="88%"></div></div>
                            </div>
                            <!-- Skill -->
                            <div class="about-skill-item">
                                <div class="flex justify-between text-sm uppercase tracking-widest mb-3 font-medium">
                                    <span><i class="fa-solid fa-font text-accent mr-2"></i>Typography</span>
                                    <span class="text-accent">87%</span>
                                </div>
                                <div class="skill-bar-bg rounded-full h-2"><div class="skill-bar-fill rounded-full" data-width="87%"></div></div>
                            </div>
                            <!-- Skill -->
                            <div class="about-skill-item">
                                <div class="flex justify-between text-sm uppercase tracking-widest mb-3 font-medium">
                                    <span><i class="fa-solid fa-print text-accent mr-2"></i>Print Design</span>
                                    <span class="text-accent">85%</span>
                                </div>
                                <div class="skill-bar-bg rounded-full h-2"><div class="skill-bar-fill rounded-full" data-width="85%"></div></div>
                            </div>
                            <!-- Skill -->
                            <div class="about-skill-item">
                                <div class="flex justify-between text-sm uppercase tracking-widest mb-3 font-medium">
                                    <span><i class="fa-solid fa-wand-magic-sparkles text-accent mr-2"></i>Motion Graphics</span>
                                    <span class="text-accent">80%</span>
                                </div>
                                <div class="skill-bar-bg rounded-full h-2"><div class="skill-bar-fill rounded-full" data-width="80%"></div></div>
                            </div>
                        </div>
                    </div>

                    <!-- Tools -->
                    <div class="space-y-8">
                        <h3 class="about-fade-up font-bebas text-4xl tracking-widest flex items-center gap-3">
                            <i class="fa-solid fa-layer-group text-accent"></i> Software Stack
                        </h3>
                        <div class="flex flex-wrap gap-4">
                            <div class="about-tool-tag tool-tag border border-white/10 rounded-lg px-6 py-4 text-sm font-medium uppercase tracking-widest bg-white/5 backdrop-blur-md shadow-lg"><i class="fa-brands fa-adobe mr-2 text-accent"></i>Photoshop</div>
                            <div class="about-tool-tag tool-tag border border-white/10 rounded-lg px-6 py-4 text-sm font-medium uppercase tracking-widest bg-white/5 backdrop-blur-md shadow-lg"><i class="fa-brands fa-adobe mr-2 text-accent"></i>Illustrator</div>
                            <div class="about-tool-tag tool-tag border border-white/10 rounded-lg px-6 py-4 text-sm font-medium uppercase tracking-widest bg-white/5 backdrop-blur-md shadow-lg"><i class="fa-brands fa-adobe mr-2 text-accent"></i>InDesign</div>
                            <div class="about-tool-tag tool-tag border border-white/10 rounded-lg px-6 py-4 text-sm font-medium uppercase tracking-widest bg-white/5 backdrop-blur-md shadow-lg"><i class="fa-solid fa-video mr-2 text-accent"></i>Premiere Pro</div>
                            <div class="about-tool-tag tool-tag border border-white/10 rounded-lg px-6 py-4 text-sm font-medium uppercase tracking-widest bg-white/5 backdrop-blur-md shadow-lg"><i class="fa-solid fa-film mr-2 text-accent"></i>After Effects</div>
                            <div class="about-tool-tag tool-tag border border-white/10 rounded-lg px-6 py-4 text-sm font-medium uppercase tracking-widest bg-white/5 backdrop-blur-md shadow-lg"><i class="fa-solid fa-pen-nib mr-2 text-accent"></i>Canva</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Experience Section -->
